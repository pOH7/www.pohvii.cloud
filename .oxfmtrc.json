{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "trailingComma": "es5",
  "singleQuote": false,
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "bracketSpacing": true,
  "jsxSingleQuote": false,
  "proseWrap": "preserve",
  "sortImports": {},
  "sortTailwindcss": {
    "stylesheet": "./app/globals.css",
    "functions": ["cn", "clsx", "cva"]
  },
  "ignorePatterns": [
    "node_modules/**",
    ".next/**",
    "out/**",
    "build/**",
    "output/**",
    "playwright-report/**",
    "test-results/**",
    "next-env.d.ts",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock"
  ]
}
