{
  "name": "www.pohvii.cloud",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vinext dev",
    "build": "node scripts/generate-static-metadata.mjs && vinext build",
    "start": "vinext start",
    "prepare:static-deploy": "node scripts/clear-vinext-deploy-redirect.mjs",
    "deploy": "pnpm run build && pnpm run prepare:static-deploy && wrangler deploy --config wrangler.jsonc --env=\"\"",
    "deploy:staging": "pnpm run build && pnpm run prepare:static-deploy && wrangler deploy --config wrangler.jsonc --env staging",
    "deploy:production": "pnpm run build && pnpm run prepare:static-deploy && wrangler deploy --config wrangler.jsonc --env=\"\"",
    "deploy:preview": "pnpm run build && pnpm run prepare:static-deploy && wrangler versions upload --config wrangler.jsonc --env=\"\"",
    "deploy:dry-run": "pnpm run build && pnpm run prepare:static-deploy && wrangler deploy --config wrangler.jsonc --env=\"\" --dry-run --outdir bundled-static",
    "cf:types": "wrangler types",
    "lint": "oxlint --type-aware .",
    "lint:fix": "oxlint --type-aware --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prepare": "husky",
    "test:worker": "node --experimental-strip-types --test tests/static-assets-worker.test.ts",
    "test:e2e": "playwright test",
    "verify:static-blog": "node scripts/verify-static-blog.mjs"
  },
  "dependencies": {
    "@chevrotain/regexp-to-ast": "12.0.0",
    "@excalidraw/excalidraw": "^0.18.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/hast": "^3.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "hls.js": "^1.6.16",
    "lenis": "^1.3.21",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.14.0",
    "next-themes": "^0.4.6",
    "pdfjs-dist": "^5.6.205",
    "plyr": "^3.8.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-zoom-pan-pinch": "^4.0.3",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "shiki": "^4.0.2",
    "simple-icons": "^16.16.0",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.3",
    "@cloudflare/workers-types": "^4.20260508.1",
    "@mdx-js/rollup": "3.1.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-rsc": "^0.5.26",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.0",
    "react-server-dom-webpack": "^19.2.6",
    "remark-frontmatter": "5.0.0",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vinext": "^0.0.49",
    "vite": "^8.0.11",
    "wrangler": "^4.90.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "oxlint --type-aware --fix --no-error-on-unmatched-pattern",
      "oxfmt --write"
    ],
    "*.{json,md,mdx,css,html,yml,yaml,toml}": [
      "oxfmt --write"
    ]
  },
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "overrides": {
      "@excalidraw/excalidraw>nanoid": "3.3.8",
      "@excalidraw/mermaid-to-excalidraw>nanoid": "5.0.9",
      "@excalidraw/mermaid-to-excalidraw>mermaid": "10.9.4",
      "mermaid@10.9.4>dompurify": "3.2.4",
      "@prisma/dev>hono": "4.12.3",
      "lodash": "4.17.23"
    }
  }
}
